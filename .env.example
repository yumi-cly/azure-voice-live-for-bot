# Copy this file to .env for local development.
# Do not commit .env. The browser never receives keys or endpoints; FastAPI broker reads them server-side.
#
# Preferred auth:
# - Local dev: run az login.
# - Azure Container Apps: use the user-assigned managed identity created by provision-demo-resources.ps1.
# - Leave key variables empty unless you explicitly choose API-key auth for a specific local test.

# 1. Azure resources
# These values are written by provision-demo-resources.ps1 -UpdateEnv.
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
FOUNDRY_RESOURCE_NAME=
FOUNDRY_REGION=
VOICE_LIVE_ENDPOINT=
VOICE_LIVE_API_VERSION=2026-04-10
VOICE_LIVE_ASR_MODEL=azure-speech
VOICE_LIVE_AGENT_MODEL=gpt-5.4
VOICE_LIVE_TTS_VOICE=zh-CN-Xiaoxiao:DragonHDFlashLatestNeural

AZURE_AI_SEARCH_SERVICE_NAME=
AZURE_AI_SEARCH_LOCATION=
FOUNDRY_IQ_SEARCH_ENDPOINT=

AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_BLOB_SERVICE_URL=
AZURE_STORAGE_CONTAINER_NAME=kb-docs
AZURE_STORAGE_LOCATION=

AZURE_CONTAINER_APPS_ENVIRONMENT_NAME=
AZURE_CONTAINER_APPS_LOCATION=
AZURE_CONTAINER_REGISTRY_LOCATION=
AZURE_MANAGED_IDENTITY_LOCATION=

# 2. Microsoft Foundry project, model, agent, and IQ
# Fill these after creating the project/model/agent/knowledge base in Microsoft Foundry.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_PROJECT_NAME=
FOUNDRY_PROJECT_RESOURCE_ID=
FOUNDRY_MODEL_NAME=
FOUNDRY_VISION_DEPLOYMENT=
FOUNDRY_AGENT_NAME=
# Optional. Leave empty to let the deploy script use the latest active Agent version as the base.
FOUNDRY_AGENT_VERSION=
FOUNDRY_IQ_KNOWLEDGE_BASE=

# 3. Runtime values
# MCP_SERVER_URL is written by deploy-container-app.ps1 after the Container App URL is known.
MCP_SERVER_URL=
WEB_ALLOWED_ORIGINS=http://127.0.0.1:8000

# 4. Optional API-key auth
# Keep empty for the recommended Entra ID / managed identity path.
FOUNDRY_RESOURCE_KEY=
FOUNDRY_API_KEY=
VOICE_LIVE_API_KEY=

# Optional future integrations.
AZURE_KEY_VAULT_NAME=
