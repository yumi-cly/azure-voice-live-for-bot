# Copy this file to .env for local development.
# Do not commit .env. The browser never receives keys or endpoints; FastAPI broker reads them server-side.
#
# Preferred auth for Voice Live Agent Mode:
# - Local dev: az login with an identity that can access the Foundry resource.
# - Azure Container Apps: assign a managed identity with access to the Foundry resource.
# - Leave VOICE_LIVE_API_KEY empty for Agent Mode.

AZURE_RESOURCE_GROUP=
AZURE_CLIENT_ID=
FOUNDRY_RESOURCE_NAME=
FOUNDRY_REGION=
FOUNDRY_RESOURCE_KEY=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_BLOB_SERVICE_URL=
AZURE_STORAGE_CONTAINER_NAME=
AZURE_AI_SEARCH_SERVICE_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT_NAME=
AZURE_KEY_VAULT_NAME=
AZURE_TENANT_ID=
VOICE_LIVE_ENDPOINT=
VOICE_LIVE_API_KEY=
VOICE_LIVE_API_VERSION=2026-04-10

FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_PROJECT_NAME=
FOUNDRY_AGENT_NAME=
FOUNDRY_AGENT_ID=
FOUNDRY_AGENT_VERSION=
FOUNDRY_WEB_AGENT_NAME=
FOUNDRY_WEB_AGENT_ID=
FOUNDRY_WEB_AGENT_VERSION=
FOUNDRY_MODEL_NAME=
FOUNDRY_VISION_DEPLOYMENT=gpt-5.4
FOUNDRY_PROJECT_RESOURCE_ID=
FOUNDRY_IQ_SEARCH_ENDPOINT=
FOUNDRY_IQ_KNOWLEDGE_BASE=
FOUNDRY_IQ_CONNECTION_NAME=foundry-iq-kb
MCP_SERVER_URL=

WEB_ALLOWED_ORIGINS=http://127.0.0.1:8000
